# StuNet Environment Variables

# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/StuNet
# Or MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/StuNet

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this

# AI - Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (optional - for OTP & storage)
# FIREBASE_API_KEY=
# FIREBASE_PROJECT_ID=

# AWS S3 (optional - for file storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=
